958678,-0.01553813,-0.01096349,0.04918228,0.20018905,0.01064646,-0.02415828,0.00033719,-0.04090233,0.02924548,-0.0028543,0.04353569,-0.00745127,-0.00355333,0.06403401,0.04526656,-0.01473974,0.04447665,0.01041206,-0.01266176,0.00404776,-0.04909978,-0.11420356,-0.00409374,-0.02360317,0.03593121,0.07745506,-0.00727416,-0.02038473,-0.06791196,0.03085039,0.03558501,-0.01757226,-0.02070036,-0.02948029,0.01878618,-0.076984,0.0129027,-0.00357291,0.01489169,-0.02295054,-0.00210234,-0.01166563,-0.05758684,-0.00520714,0.01902745,-0.04123369],"last_embed":{"tokens":467,"hash":"1g4vc18"}}},"last_read":{"hash":"1g4vc18","at":1777924054945},"class_name":"SmartSource","last_import":{"mtime":1777914665010,"size":3868,"at":1777924053308,"hash":"1g4vc18"},"blocks":{"#ES07 Informazioni Geografiche":[1,120],"#ES07 Informazioni Geografiche#{1}":[2,4],"#ES07 Informazioni Geografiche#1. Rappresentare il diagrammi ER facendo uso, dove opportuno, di gerarchie di entità. Corredare l'ER con regole di lettura.":[5,5],"#ES07 Informazioni Geografiche#2. Trasformare poi il diagramma ER in schema logico relazionale indicando chiaramente le chiavi, i riferimenti ed i vincoli che ti sembrano degni di nota":[6,6],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:":[7,120],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#a. Creare almeno due tabelle fra esse correlate, esprimendo tutti i vincoli degni di nota":[8,8],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#b. Si desidera conoscere il nome del/dei fiume/i più lungo/hi fra quelli che attraversano il territorio tedesco.":[9,9],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#c. Numero dei laghi presenti sul territorio italiano.":[10,10],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#d. Superficie media delle nazioni presenti nella base di dati.":[11,11],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#e. Elenco alfabetico delle nazioni attraversate dal fiume Danubio, con l'indicazione della relativa lunghezza del suo percorso in ciascuna nazione.":[12,12],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#f. Elenco degli emissari del Lago di Garda.":[13,120],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#f. Elenco degli emissari del Lago di Garda.#{1}":[15,120]},"outlinks":[],"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Informatica 07.md"},"smart_blocks:Informatica 07.md#ES07 Informazioni Geografiche": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1g4vc18","at":1777924053305},"key":"Informatica 07.md#ES07 Informazioni Geografiche","lines":[1,120],"size":3797,"outlinks":[],"class_name":"SmartBlock"},
