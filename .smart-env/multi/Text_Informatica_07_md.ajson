ichieste:#e. Elenco alfabetico delle nazioni attraversate dal fiume Danubio, con l'indicazione della relativa lunghezza del suo percorso in ciascuna nazione.":[23,24],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#f. Elenco degli emissari del Lago di Garda.":[25,161],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#f. Elenco degli emissari del Lago di Garda.#{1}":[27,161]},"outlinks":[],"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:Text/Informatica 07.md#ES07 Informazioni Geografiche": {"path":null,"last_embed":{"hash":"192zo8h","at":1778134979406},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.07212749,0.04802631,0.05883233,0.02224235,0.02133975,0.02522559,0.00206122,0.0219647,0.00002362,0.01514028,-0.03492271,-0.07723189,0.06804213,0.07502652,-0.01629368,-0.03508707,-0.03175962,0.02571647,-0.0283953,-0.00298645,0.16785379,0.007228,-0.01580634,-0.02468033,0.00737439,0.13183977,-0.00193828,0.0051631,-0.04728963,-0.19514662,0.00704663,0.05871015,0.09691072,-0.02651715,-0.05168376,0.03861649,-0.03964262,0.02965474,-0.05930084,0.06278761,0.03085176,0.03988418,0.02904535,-0.03373335,0.00006644,-0.06877452,-0.00877685,0.00894115,-0.04181875,0.01069369,-0.04702743,0.00276875,0.04830818,0.05262393,-0.01180584,0.09906749,0.00959853,-0.00802292,0.03912368,0.02492611,0.02654274,0.02647624,-0.21332006,0.01172793,-0.00477977,0.0098262,-0.04390495,-0.03322589,-0.02985018,-0.01522973,-0.00545627,0.01872607,0.01643119,0.08150502,0.07086878,-0.00537276,-0.02831681,0.05480277,-0.02406747,-0.01098392,0.04304789,0.0803716,-0.03439052,0.00273666,-0.03827953,-0.06407733,0.02052806,0.02891227,0.06976022,0.01007636,-0.00420318,-0.01726978,0.02207056,0.04731023,0.02988836,-0.00608104,-0.07578119,0.00550339,0.01243045,0.0587319,-0.02574352,-0.02725567,0.05701919,0.04819581,0.0319977,-0.00598185,0.00613149,-0.0773531,-0.01323252,0.02081813,-0.05102699,-0.04377955,0.00479016,-0.03670038,0.00799437,0.01409922,0.05845223,