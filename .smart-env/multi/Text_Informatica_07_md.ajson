67494,0.01021674,-0.01963602,-0.03088917,0.03533911,0.17795223,0.01159271,-0.02191627,-0.00583311,-0.05548058,0.01863097,0.00038016,0.06289782,0.01056113,-0.01537327,0.08744393,0.05388202,-0.02908766,0.05823648,-0.00392633,-0.00647225,0.00048474,-0.03779481,-0.08799309,-0.00017072,-0.03668328,0.02772344,0.06876857,0.01030889,-0.02497272,-0.04521459,0.01364064,0.04086423,-0.02066572,-0.04604183,-0.05424744,0.02797595,-0.04198489,0.0030077,-0.01097737,0.01288585,-0.04109933,-0.00930257,-0.02761868,-0.05923679,0.02386959,0.01210422,-0.03056518],"last_embed":{"tokens":466,"hash":"1g4vc18"}}},"last_read":{"hash":"1g4vc18","at":1778135649790},"class_name":"SmartSource","last_import":{"mtime":1778135629737,"size":3868,"at":1778135649476,"hash":"1g4vc18"},"blocks":{"#ES07 Informazioni Geografiche":[1,120],"#ES07 Informazioni Geografiche#{1}":[2,4],"#ES07 Informazioni Geografiche#1. Rappresentare il diagrammi ER facendo uso, dove opportuno, di gerarchie di entità. Corredare l'ER con regole di lettura.":[5,5],"#ES07 Informazioni Geografiche#2. Trasformare poi il diagramma ER in schema logico relazionale indicando chiaramente le chiavi, i riferimenti ed i vincoli che ti sembrano degni di nota":[6,6],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:":[7,120],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#a. Creare almeno due tabelle fra esse correlate, esprimendo tutti i vincoli degni di nota":[8,8],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#b. Si desidera conoscere il nome del/dei fiume/i più lungo/hi fra quelli che attraversano il territorio tedesco.":[9,9],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#c. Numero dei laghi presenti sul territorio italiano.":[10,10],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#d. Superficie media delle nazioni presenti nella base di dati.":[11,11],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#e. Elenco alfabetico delle nazioni attraversate dal fiume Danubio, con l'indicazione della relativa lunghezza del suo percorso in ciascuna nazione.":[12,12],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#f. Elenco degli emissari del Lago di Garda.":[13,120],"#ES07 Informazioni Geografiche#3. Esprimere in SQL le seguenti richieste:#f. Elenco degli emissari del Lago di Garda.#{1}":[15,120]},"outlinks":[],"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:Text/Informatica 07.md#ES07 Informazioni Geografiche": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1g4vc18","at":1778135649472},"key":"Text/Informatica 07.md#ES07 Informazioni Geografiche","lines":[1,120],"size":3797,"outlinks":[],"class_name":"SmartBlock"},
